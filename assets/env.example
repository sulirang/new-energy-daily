# AI API. Any OpenAI-compatible endpoint works.
AI_API_KEY=your_api_key
AI_BASE_URL=https://api.openai.com/v1
AI_MODEL=gpt-4o-mini

# Exa search. Put one key per line in the key file.
EXA_KEYS_FILE=config/exa_keys.txt
EXA_KEY_STATE_FILE=config/exa_key_state.json

# Optional alternatives. EXA_API_KEY remains supported for one legacy key.
EXA_API_KEYS=
EXA_API_KEY=

# Firecrawl-hosted browser for GME electricity prices.
FIRECRAWL_KEY_FILE=config/firecrawl_key.txt
FIRECRAWL_API_KEY=
FIRECRAWL_API_BASE=https://api.firecrawl.dev

# Agent Mail sending. Run `agently-cli auth login` once on the VPS first.
AGENT_MAIL_CLI=agently-cli
AGENT_MAIL_RECIPIENTS=recipient1@example.com,recipient2@example.com

# Optional.
REPORT_TIMEZONE=Europe/Rome
COLLECTION_CUTOFF_TIME=12:30
REPORT_SUBJECT_PREFIX=新能源日报
